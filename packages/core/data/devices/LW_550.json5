{
  key: 'LW_550',
  name: 'LabelWriter 550',
  family: 'labelwriter',
  transports: {
    usb: { vid: '0x0922', pid: '0x0028' },
  },
  engines: [
    {
      role: 'primary',
      protocol: 'lw5-raster',
      dpi: 300,
      headDots: 672,
      mediaCompatibility: ['lw'],
      capabilities: {
        mediaDetection: true,
        // Driver-side capability: Dymo-only NFC roll authentication.
        // Promote to a contracts-named key when a second vendor lands a
        // comparable mechanism (cassette-ID, RFID auth, etc.).
        genuineMediaRequired: true,
      },
      // Chassis leading dead zone — bench-validated across LW 3xx/4xx/5xx
      // (2026-05-08). See LW_300.json5 for rationale. The 5xx NFC tag
      // can additionally provide per-roll `printableHorizontalOffsetMm`
      // / `printableVerticalOffsetMm`; `getPrintableArea(engine, media)`
      // prefers tag-supplied values when present and falls back to this
      // engine default otherwise.
      printableArea: { leading: 6, trailing: 0, left: 0, right: 0 },
    },
  ],
  hardwareQuirks: 'NFC-based roll authentication: refuses non-genuine rolls outright. On genuine rolls, the NFC-defined length is authoritative — host claims to print at a different length are silently overridden, manifesting as a misprint at NFC dimensions. Apps that compare detected vs selected media should warn the user before sending.',
  support: { status: 'untested' },
}

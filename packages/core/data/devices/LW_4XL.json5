{
  key: 'LW_4XL',
  name: 'LabelWriter 4XL',
  family: 'labelwriter',
  transports: {
    // PID unconfirmed — 4XL is rare in lsusb logs. Best community guess.
    usb: { vid: '0x0922', pid: '0x001f' },
  },
  engines: [
    // 4" wide head: 1248 dots / 156 bytes per dymo-cups-drivers
    // (4" × 300 dpi = 1200 dots + 48-dot margin convention).
    {
      role: 'primary',
      protocol: 'lw-450',
      dpi: 300,
      headDots: 1248,
      mediaCompatibility: ['lw', 'lw-wide'],
      // Chassis leading dead zone — bench-validated across LW 3xx/4xx/5xx
      // (2026-05-08). See LW_300.json5 for rationale.
      printableArea: { leading: 6, trailing: 0, left: 0, right: 0 },
    },
  ],
  support: { status: 'untested' },
}

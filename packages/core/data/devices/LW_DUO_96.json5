{
  key: 'LW_DUO_96',
  name: 'LabelWriter Duo - 96',
  family: 'labelwriter',
  // Composite USB device: two interfaces — one for the label head
  // (lw-raster protocol) and one for the D1 tape head (d1-tape protocol).
  // Tape engine becomes drivable when a `d1-tape` protocol module is
  // registered with the runtime resolver; until then the resolver
  // returns the device with `engines.tape.drivable: false`.
  transports: {
    usb: { vid: '0x0922', pid: '0x0017' },
  },
  engines: [
    {
      role: 'label',
      protocol: 'lw-raster',
      dpi: 300,
      headDots: 672,
      mediaCompatibility: ['lw'],
      bind: { usb: { bInterfaceNumber: 0 } },
      // Chassis leading dead zone — bench-validated across LW 3xx/4xx/5xx
      // (2026-05-08). See LW_300.json5 for rationale. d1-tape engine
      // below is a separate chassis path; no leading dead zone there.
      printableArea: { leading: 6, trailing: 0, left: 0, right: 0 },
    },
    {
      role: 'tape',
      protocol: 'd1-tape',
      dpi: 180,
      // 96-dot tape head — bytes-per-line max 12 per LW 450 Series
      // Tech Ref Appendix B p.23.
      headDots: 96,
      mediaCompatibility: ['d1'],
      capabilities: { autocut: true },
      bind: { usb: { bInterfaceNumber: 1 } },
      // D1 cassette dead-zone defaults — Duo tape side is
      // electrically a LabelManager. See LM_PNP.json5 for the
      // geometry rationale (centred-strip math: leading 0 + 16mm
      // trailing pad → 8mm leading + 8mm trailing per cut strip in
      // steady state). Bench-confirm per chassis as needed.
      printableArea: { leading: 0, trailing: 0, left: 0, right: 0 },
      forcedTrailingFeedMm: 16,
    },
  ],
  support: { status: 'untested' },
}

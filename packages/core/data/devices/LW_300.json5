{
  key: 'LW_300',
  name: 'LabelWriter 300',
  family: 'labelwriter',
  // PID 0x0009 is registered as "LabelWriter 310" upstream (linux-usb.org
  // usb.ids); the LW 300 and 310 share the entry per dymo-cups-drivers.
  transports: {
    usb: { vid: '0x0922', pid: '0x0009' },
    serial: { defaultBaud: 115200, supportedBauds: [115200] },
  },
  engines: [
    {
      role: 'primary',
      protocol: 'lw-450',
      dpi: 300,
      // 464 dots / 58 bytes per dymo-cups-drivers (clamps from 1.57" × 300 = 471).
      headDots: 464,
      mediaCompatibility: ['lw'],
      // Chassis-physical leading dead zone — bench-validated 2026-05-08
      // across LW 330 Turbo / 400 / 450; the head sits ~6 mm past the
      // leading edge after partial pull-back. Single value applies to
      // every LW 3xx/4xx/5xx engine in the registry. Other axes stay 0.
      // `forcedTrailingFeedMm` left absent — LW family uses variable
      // form-feed (`ESC E` to next tear bar).
      printableArea: { leading: 6, trailing: 0, left: 0, right: 0 },
    },
  ],
  support: { status: 'untested' },
}

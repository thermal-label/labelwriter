{
  key: 'LW_DUO_128',
  name: 'LabelWriter Duo - 128',
  family: 'labelwriter',
  transports: {
    usb: { vid: '0x0922', pid: '0x001d' },
  },
  engines: [
    {
      role: 'label',
      protocol: 'lw-450',
      dpi: 300,
      headDots: 672,
      mediaCompatibility: ['standard'],
      bind: { usb: { bInterfaceNumber: 0 } },
    },
    {
      role: 'tape',
      protocol: 'd1-tape',
      dpi: 180,
      headDots: 128,
      mediaCompatibility: ['d1'],
      capabilities: { autocut: true },
      bind: { usb: { bInterfaceNumber: 1 } },
    },
  ],
  support: { status: 'untested' },
}

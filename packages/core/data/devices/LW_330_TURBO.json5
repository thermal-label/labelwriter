{
  key: 'LW_330_TURBO',
  name: 'LabelWriter 330 Turbo',
  family: 'labelwriter',
  // DYMO part #90793. USB PID 0x0008 confirmed via lsusb on a real unit:
  //   Bus 003 Device 005: ID 0922:0008 Dymo-CoStar Corp. DYMO LabelWriter 330 Turbo
  // Same head as LW_330 (672 dots / 84 bytes per dymo-cups-drivers
  // lw330t.ppd); the "Turbo" in the name refers to motor speed, not
  // print width.
  transports: {
    usb: { vid: '0x0922', pid: '0x0008' },
    serial: { defaultBaud: 115200, supportedBauds: [115200] },
  },
  engines: [
    {
      role: 'primary',
      protocol: 'lw-raster',
      dpi: 300,
      headDots: 672,
      mediaCompatibility: ['lw'],
      // Chassis-physical leading dead zone — bench-validated 2026-05-08
      // across LW 330 Turbo / 400 / 450; the head sits ~6 mm past the
      // leading edge after partial pull-back. Single value applies to
      // every LW 3xx/4xx/5xx engine in the registry. Other axes stay 0
      // (variable form-feed handles trailing; the 25-dot symmetric
      // label overhang at left/right is media geometry, not a chassis
      // offset within the buffer). `forcedTrailingFeedMm` left absent
      // — LW family uses variable form-feed (`ESC E` to next tear bar).
      printableArea: { leading: 6, trailing: 0, left: 0, right: 0 },
    },
  ],
  // USB-printed against on real hardware (May 2026, lever-arch SKU 99019):
  // discovery, status read, encoder bytes accepted end-to-end, ink lays
  // down. The chassis-offset / label-pitch modelling gaps surfaced by
  // this print (see plans/backlog/chassis-offset-and-pitch-semantics.md)
  // are cross-cutting registry concerns, not device-specific defects —
  // gating 'verified' on them would leave the whole driver stuck at
  // 'partial'. The driver does drive this unit end-to-end, so call it
  // verified and track the margin work as its own plan.
  support: { status: 'verified', transports: { usb: 'verified' } },
}
